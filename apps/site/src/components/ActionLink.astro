---
import { isExternalHref } from '../lib/utils';

interface Props {
  href?: string | null;
  label?: string | null;
  variant?: 'primary' | 'secondary' | 'ghost' | 'green';
  className?: string;
}

const {
  href = '#',
  label = 'Learn more',
  variant = 'primary',
  className = '',
} = Astro.props as Props;

const external = isExternalHref(href);

const variantClasses = {
  primary:
    'bg-[var(--color-plum)] !text-white shadow-[0_4px_12px_rgba(96,19,80,0.16)] hover:shadow-[0_16px_32px_rgba(96,19,80,0.25)]',
  secondary:
    '!border-[var(--color-plum)] bg-[var(--color-surface)] !text-[var(--color-plum)] shadow-sm hover:shadow-md',
  ghost:
    'border-[rgba(15,15,18,0.14)] bg-transparent text-[var(--color-text)] shadow-none hover:shadow-sm',
  green:
    '!border-[#0a7114] !bg-white !text-[#0a7114] shadow-[0_4px_12px_rgba(10,113,20,0.1)] hover:!bg-[#0a7114] hover:!text-white hover:shadow-[0_16px_32px_rgba(10,113,20,0.25)] btn-shimmer-green',
};
---

<style>
  /* Glossy Shimmer Effect (Transform-based for reliable hover triggering) */
  .btn-shimmer::after {
    content: '';
    position: absolute;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    background: linear-gradient(
      90deg,
      transparent,
      rgba(255, 255, 255, 0.4),
      transparent
    );
    transform: skewX(-20deg) translateX(-150%);
    transition: transform 0.6s ease-in-out;
    z-index: 1;
    pointer-events: none;
  }

  .btn-shimmer:hover::after {
    transform: skewX(-20deg) translateX(150%);
  }

  /* Green variant adjusted shimmer */
  .btn-shimmer-green.btn-shimmer::after {
    background: linear-gradient(
      90deg,
      transparent,
      rgba(10, 113, 20, 0.12),
      transparent
    );
  }
</style>

<a
  href={href || '#'}
  class:list={[
    /* Base Layout */
    'inline-flex min-h-[2.9rem] items-center justify-center rounded-full border border-transparent px-4 py-3 font-bold no-underline',

    /* Positioning for Shimmer */
    'relative overflow-hidden',

    /* ✅ Smooth Transitions for Transform, Colors, and Box-Shadow */
    'transition-all duration-300 ease-in-out',

    /* Hover Lift */
    'hover:-translate-y-1',

    /* Variant Styles (includes default + hover states + shimmer modifier) */
    variantClasses[variant],

    /* Shimmer Trigger */
    'btn-shimmer',

    /* User Overrides */
    className,
  ]}
  target={external ? '_blank' : undefined}
  rel={external ? 'noreferrer' : undefined}
>
  {label}
</a>
