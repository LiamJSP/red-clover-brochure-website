---
import ActionLink from '../ActionLink.astro';
import SectionIntro from '../SectionIntro.astro';
import type { ContactMethodsBlock } from '../../lib/types';

interface Props {
  block: ContactMethodsBlock;
}

const { block } = Astro.props as Props;
const enableEmbed =
  import.meta.env.PUBLIC_ENABLE_CALENDLY_EMBED === 'true' &&
  Boolean(block.embedUrl);

// Calculate visible items to dynamically adjust grid columns
const hasEmail = Boolean(block.email);
const hasCalendly = Boolean(block.calendlyUrl);
const hasPhone = Boolean(block.phone);
const visibleCount =
  (hasEmail ? 1 : 0) + (hasCalendly ? 1 : 0) + (hasPhone ? 1 : 0);

// Determine grid class based on visible count
const gridClass =
  visibleCount === 2
    ? 'min-[981px]:grid-cols-2'
    : visibleCount === 3
      ? 'min-[981px]:grid-cols-3'
      : '';
---

<section class="bg-[rgba(255,255,255,0.6)] py-10">
  <div class="mx-auto w-[min(1120px,calc(100%-2rem))]">
    <SectionIntro
      eyebrow={block.eyebrow}
      heading={block.heading}
      intro={block.intro}
    />

    <div class:list={[gridClass, "grid grid-cols-1 gap-4"]}>
      {
        hasEmail && (
          <article class="rounded-[18px] border border-[rgba(15,15,18,0.08)] bg-[rgba(255,255,255,0.9)] p-[1.35rem] shadow-[0_10px_30px_rgba(15,15,18,0.04)]">
            <h3>{block.emailLabel || 'Email your scenario'}</h3>
            <p>
              Describe what is working, what is risky, and where you need help.
              That is enough to start.
            </p>
            <ActionLink
              href={`mailto:${block.email}`}
              label="Email us"
              variant="primary"
            />
          </article>
        )
      }

      {
        hasCalendly && (
          <article class="rounded-[18px] border border-[rgba(15,15,18,0.08)] bg-[rgba(255,255,255,0.9)] p-[1.35rem] shadow-[0_10px_30px_rgba(15,15,18,0.04)]">
            <h3>{block.calendlyLabel || 'Book a call'}</h3>
            <p>
              Use a short discovery call when the scenario is easier to explain
              live.
            </p>
            <ActionLink
              href={block.calendlyUrl}
              label="Open booking page"
              variant="secondary"
            />
          </article>
        )
      }

      {
        hasPhone && (
          <article class="rounded-[18px] border border-[rgba(15,15,18,0.08)] bg-[rgba(255,255,255,0.9)] p-[1.35rem] shadow-[0_10px_30px_rgba(15,15,18,0.04)]">
            <h3>{block.phoneLabel || 'Phone'}</h3>
            <p>
              Use this only for urgent production issues or pre-arranged calls.
            </p>
            <ActionLink
              href={`tel:${block.phone}`}
              label="Call us"
              variant="ghost"
            />
          </article>
        )
      }
    </div>

    {
      block.responseWindows && block.responseWindows.length > 0 && (
        <div class="mt-4 grid grid-cols-1 gap-4 min-[761px]:grid-cols-2">
          {block.responseWindows.map((item) => (
            <article class="grid grid-cols-[auto_1fr] gap-[0.9rem] rounded-[18px] border border-[rgba(15,15,18,0.08)] bg-[rgba(255,255,255,0.9)] px-[1.2rem] py-[1.1rem] shadow-[0_10px_30px_rgba(15,15,18,0.04)]">
              <span
                class="mt-[0.5rem] h-[0.9rem] w-[0.9rem] rounded-full [background:linear-gradient(135deg,var(--color-plum),var(--color-green))]"
                aria-hidden="true"
              />
              <div>
                <h3>{item.label}</h3>
                <p>{item.description}</p>
              </div>
            </article>
          ))}
        </div>
      )
    }

    {
      block.note && (
        <p class="mt-4 text-[var(--color-text-soft)]">{block.note}</p>
      )
    }

    {
      enableEmbed && block.embedUrl && (
        <div class="mt-4 overflow-hidden rounded-[28px] border border-[rgba(15,15,18,0.08)] shadow-[0_18px_40px_rgba(15,15,18,0.06)]">
          <iframe
            title="Calendly scheduling"
            src={block.embedUrl}
            loading="lazy"
            width="100%"
            height="780"
            class="border-0 bg-[var(--color-surface)]"
          />
        </div>
      )
    }
  </div>
</section>
