---
import SectionIntro from '../SectionIntro.astro';
import { markdownToHtml } from '../../lib/markdown';
import type { FAQBlock } from '../../lib/types';

interface Props {
  block: FAQBlock;
}

const { block } = Astro.props as Props;
---

<section class="py-10">
  <div class="mx-auto w-[min(1120px,calc(100%-2rem))]">
    <SectionIntro
      eyebrow={block.eyebrow}
      heading={block.heading}
      intro={block.intro}
    />

    <div class="grid gap-[0.8rem]">
      {
        block.items.map((item) => (
          <details class="rounded-[18px] border border-[rgba(15,15,18,0.08)] bg-[rgba(255,255,255,0.92)] px-[1.15rem] py-4">
            <summary class="cursor-pointer list-none text-[1.05rem] font-bold [&::-webkit-details-marker]:hidden">
              {item.question}
            </summary>
            <div
              class="max-w-[65ch] pt-[0.85rem] text-[var(--color-text)] [&_a]:text-[var(--color-plum)] [&_blockquote]:mb-4 [&_blockquote]:ml-0 [&_blockquote]:border-l-[3px] [&_blockquote]:border-l-[rgba(96,19,80,0.25)] [&_blockquote]:pl-4 [&_blockquote]:text-[var(--color-text-soft)] [&_h2]:mb-4 [&_h3]:mb-4 [&_ol]:mb-4 [&_ol]:pl-5 [&_p]:mb-4 [&_ul]:mb-4 [&_ul]:pl-5"
              set:html={markdownToHtml(item.answer)}
            />
          </details>
        ))
      }
    </div>
  </div>
</section>
