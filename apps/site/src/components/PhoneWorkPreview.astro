---
interface CmsMediaAsset {
  url?: string | null;
  alt?: string | null;
  width?: number | null;
  height?: number | null;
}

interface Props {
  image?: CmsMediaAsset | null;
  label?: string | null;
}

const VIEWPORT_WIDTH = 1320;
const HOLD_MS = 3000;
const STEP_MS = 700;
const REWIND_MS = 450;
const IPHONE_FRAME_SRC = '/iphone17promax.png';
const BG_IMAGE_SRC = '/clover_large.png';

const { image, label } = Astro.props as Props;

const imageUrl = image?.url ?? null;
const rawSlideCount = image?.width ? image.width / VIEWPORT_WIDTH : 1;
const slideCount = Number.isFinite(rawSlideCount)
  ? Math.max(1, Math.round(rawSlideCount))
  : 1;

const alt =
  image?.alt || label || 'Website previews shown inside an iPhone frame';
---

<div
  class="phone-work-preview is-loading"
  data-phone-work-preview
  data-slide-count={slideCount}
  data-hold-ms={HOLD_MS}
  data-step-ms={STEP_MS}
  data-rewind-ms={REWIND_MS}
  style="--phone-frame-aspect:690/1408;"
>
  <img
    class="phone-work-preview__bg"
    src={BG_IMAGE_SRC}
    alt=""
    aria-hidden="true"
    loading="eager"
    decoding="async"
  />

  <div class="phone-work-preview__viewport">
    {
      imageUrl ? (
        <img
          data-phone-work-preview-strip
          class="phone-work-preview__strip"
          src={imageUrl}
          alt={alt}
          width={image?.width ?? undefined}
          height={image?.height ?? undefined}
          loading="eager"
          decoding="async"
          fetchpriority="high"
        />
      ) : (
        <div class="phone-work-preview__empty" aria-hidden="true" />
      )
    }
  </div>

  <img
    data-phone-work-preview-bezel
    class="phone-work-preview__bezel"
    src={IPHONE_FRAME_SRC}
    alt=""
    aria-hidden="true"
    loading="eager"
    decoding="async"
  />
</div>

<style>
  .phone-work-preview {
    /* Default geometry values - used before JS calculates exact geometry */
    --screen-top: 5%;
    --screen-right: 7%;
    --screen-bottom: 5%;
    --screen-left: 7%;
    --screen-radius: 10%;
    --screen-aspect: 1;
    --viewport-padding: -2px;

    position: relative;
    width: min(100%, 28rem);
    aspect-ratio: var(--phone-frame-aspect);
    margin-inline: auto;
    /* overflow-x: hidden; ← REMOVE THIS */

    /* STATE MANAGEMENT: Hidden by default to prevent layout shift/gap */
    visibility: hidden;
    opacity: 0;
    transition: opacity 0.4s ease-out;
  }

  /* Only visible when JS confirms readiness */
  .phone-work-preview.is-ready {
    visibility: visible;
    opacity: 1;
  }

  .phone-work-preview__bg {
    position: absolute;
    z-index: 0;
    top: 50%;
    left: 50%;
    width: 22rem;
    height: 22rem;
    object-fit: contain;
    pointer-events: none;
    user-select: none;
    transform: translate(3rem, -50%) rotate(30deg);
    transform-origin: center center;
  }

  .phone-work-preview__viewport {
    position: absolute;
    inset: var(--screen-top) var(--screen-right) var(--screen-bottom)
      var(--screen-left);
    overflow-x: hidden;
    margin: var(--viewport-padding);
    border-radius: var(--screen-radius) /
      calc(var(--screen-radius) * var(--screen-aspect));
    background: #0b0b0f;
    box-shadow:
      0 0 0 1px rgb(11 11 15 / 0.08) inset,
      0 0 0 2px rgb(11 11 15 / 0.12) inset;
  }

  .phone-work-preview__strip {
    --preview-offset: 0%;
    --preview-transition-ms: 0ms;
    display: block;
    height: 100%;
    width: auto;
    max-width: none;
    transform: translate3d(var(--preview-offset), 0, 0);
    transition: transform var(--preview-transition-ms)
      cubic-bezier(0.22, 1, 0.36, 1);
    will-change: transform;
  }

  .phone-work-preview__empty {
    width: 100%;
    height: 100%;
    background:
      radial-gradient(
        circle at 50% 20%,
        rgb(255 255 255 / 0.08),
        transparent 35%
      ),
      linear-gradient(180deg, rgb(255 255 255 / 0.03), rgb(255 255 255 / 0.01)),
      #0b0b0f;
  }

  .phone-work-preview__bezel {
    position: relative;
    z-index: 1;
    display: block;
    width: 100%;
    height: auto;
    pointer-events: none;
    user-select: none;
  }

  @media (max-width: 768px) {
    .phone-work-preview__bg {
      top: 0%;
      left: auto;
      right: -2.5rem;
      width: 14rem;
      height: 14rem;
      transform: translate(0, -50%) rotate(30deg);
    }
  }

  @media (prefers-reduced-motion: reduce) {
    .phone-work-preview__strip {
      transition: none;
    }
    .phone-work-preview {
      transition: none;
    }
  }
</style>

<script is:inline>
  const PHONE_PREVIEW_SELECTOR = '[data-phone-work-preview]';
  const geometryCache = new Map();

  async function getScreenGeometry(frameSrc) {
    if (geometryCache.has(frameSrc)) return geometryCache.get(frameSrc);

    const pending = (async () => {
      const img = new Image();
      img.decoding = 'async';
      img.src = frameSrc;
      // Wait for image to be fully decoded so we can read pixels
      await img.decode();

      const canvas = document.createElement('canvas');
      canvas.width = img.naturalWidth;
      canvas.height = img.naturalHeight;

      const ctx = canvas.getContext('2d', { willReadFrequently: true });
      if (!ctx) return null;

      try {
        ctx.drawImage(img, 0, 0);
        const imageData = ctx.getImageData(0, 0, canvas.width, canvas.height);
        const { data, width, height } = imageData;

        const alphaAt = (x, y) => data[(y * width + x) * 4 + 3];
        const centerX = Math.floor(width / 2);
        const centerY = Math.floor(height / 2);

        if (alphaAt(centerX, centerY) > 10) return null;

        const visited = new Uint8Array(width * height);
        const stack = [[centerX, centerY]];

        let minX = centerX;
        let maxX = centerX;
        let minY = centerY;
        let maxY = centerY;

        while (stack.length) {
          const point = stack.pop();
          if (!point) continue;

          const [x, y] = point;
          if (x < 0 || y < 0 || x >= width || y >= height) continue;

          const pixelIndex = y * width + x;
          if (visited[pixelIndex]) continue;
          visited[pixelIndex] = 1;

          if (alphaAt(x, y) > 10) continue;

          if (x < minX) minX = x;
          if (x > maxX) maxX = x;
          if (y < minY) minY = y;
          if (y > maxY) maxY = y;

          stack.push([x + 1, y], [x - 1, y], [x, y + 1], [x, y - 1]);
        }

        const screenWidth = maxX - minX + 1;
        const screenHeight = maxY - minY + 1;

        if (screenHeight === 0 || screenWidth === 0) return null;

        const sampleDepth = Math.max(4, Math.floor(screenHeight * 0.06));

        let radiusPx = 0;

        for (let y = minY; y < Math.min(maxY + 1, minY + sampleDepth); y += 1) {
          for (let x = minX; x <= maxX; x += 1) {
            if (visited[y * width + x]) {
              radiusPx = Math.max(radiusPx, x - minX);
              break;
            }
          }
        }

        radiusPx = Math.max(1, radiusPx + 2);

        return {
          top: minY / height,
          right: (width - maxX - 1) / width,
          bottom: (height - maxY - 1) / height,
          left: minX / width,
          radius: radiusPx / screenWidth,
          aspect: screenWidth / screenHeight,
        };
      } catch (e) {
        // SecurityError often happens with CORS/tainted canvas
        console.warn('Phone geometry calculation failed, using defaults', e);
        return null;
      }
    })();

    geometryCache.set(frameSrc, pending);
    return pending;
  }

  function startStripAnimation(root) {
    const strip = root.querySelector('[data-phone-work-preview-strip]');
    // Use the server-side calculated slideCount from Astro props to avoid layout measurement issues
    const slideCount = Number(root.dataset.slideCount);

    if (
      !strip ||
      slideCount <= 1 ||
      window.matchMedia('(prefers-reduced-motion: reduce)').matches
    ) {
      return;
    }

    const holdMs = Number(root.dataset.holdMs || '3000');
    const stepMs = Number(root.dataset.stepMs || '700');
    const rewindMs = Number(root.dataset.rewindMs || '450');

    let activeIndex = 0;

    const setOffset = (nextIndex, durationMs) => {
      activeIndex = nextIndex;
      strip.style.setProperty('--preview-transition-ms', `${durationMs}ms`);
      // Calculate offset as a percentage of the total strip width
      strip.style.setProperty(
        '--preview-offset',
        `${(-100 * nextIndex) / slideCount}%`
      );
    };

    const schedule = () => {
      window.setTimeout(() => {
        if (activeIndex < slideCount - 1) {
          setOffset(activeIndex + 1, stepMs);
          schedule();
          return;
        }

        setOffset(0, rewindMs);
        window.setTimeout(schedule, rewindMs);
      }, holdMs);
    };

    // Start immediately since we wait for the image to load before this function is called
    schedule();
  }

  async function initPhonePreview(root) {
    // Removed the early return check here because the caller handles it.
    // If we leave this in, it returns immediately because the caller sets the flag before calling us.

    const bezel = root.querySelector('[data-phone-work-preview-bezel]');
    const strip = root.querySelector('[data-phone-work-preview-strip]');
    const bezelSrc = bezel?.currentSrc || bezel?.getAttribute('src');

    try {
      // 1. Calculate Geometry
      if (bezelSrc) {
        const geometry = await getScreenGeometry(bezelSrc);
        if (geometry) {
          root.style.setProperty('--screen-top', `${geometry.top * 100}%`);
          root.style.setProperty('--screen-right', `${geometry.right * 100}%`);
          root.style.setProperty(
            '--screen-bottom',
            `${geometry.bottom * 100}%`
          );
          root.style.setProperty('--screen-left', `${geometry.left * 100}%`);
          root.style.setProperty(
            '--screen-radius',
            `${geometry.radius * 100}%`
          );
          root.style.setProperty('--screen-aspect', geometry.aspect);
        }
      }

      // 2. Wait for Strip Image to Load (Prevents "White Gap" flash)
      if (strip && !strip.complete) {
        await new Promise((resolve) => {
          strip.addEventListener('load', resolve, { once: true });
          strip.addEventListener('error', resolve, { once: true });
        });
      }

      // 3. Reveal Component
      root.classList.remove('is-loading');
      root.classList.add('is-ready');

      // 4. Start Animation
      startStripAnimation(root);
    } catch (err) {
      // 5. Fallback: Ensure component appears even if logic fails
      console.error('Phone preview init failed:', err);
      root.classList.remove('is-loading');
      root.classList.add('is-ready');
    }
  }

  document.addEventListener('DOMContentLoaded', () => {
    for (const root of document.querySelectorAll(PHONE_PREVIEW_SELECTOR)) {
      // Prevent running this logic multiple times on the same element
      if (root.dataset.phoneWorkPreviewReady === 'true') continue;

      root.dataset.phoneWorkPreviewReady = 'true';
      initPhonePreview(root);
    }
  });
</script>
