---
import BaseLayout from '../../layouts/BaseLayout.astro';
import ActionLink from '../../components/ActionLink.astro';
import { getAllPosts, getPostBySlug, getSiteSetting } from '../../lib/cms';
import { markdownToHtml } from '../../lib/markdown';
import { buildPageTitle, formatDate } from '../../lib/utils';

export async function getStaticPaths() {
  const posts = await getAllPosts();
  return posts.map((post) => ({
    params: { slug: post.slug },
  }));
}

const slug = Astro.params.slug || '';
const [post, settings] = await Promise.all([
  getPostBySlug(slug),
  getSiteSetting(),
]);

if (!post) {
  throw new Error('Content not found during static generation.');
}

const title = buildPageTitle(post.title, settings);
const description = post.excerpt;
const postSchema = {
  '@context': 'https://schema.org',
  '@type': 'BlogPosting',
  headline: post.title,
  description: post.excerpt,
  datePublished: post.publishedAt,
  author: {
    '@type': 'Organization',
    name: post.authorName || settings.brandName,
  },
  url: new URL(`/news/${post.slug}`, settings.siteUrl).toString(),
};
---

<BaseLayout
  settings={settings}
  pathname={`/news/${post.slug}`}
  title={title}
  description={description}
  type="article"
  articlePublishedTime={post.publishedAt}
  jsonLd={postSchema}
>
  <section class="pt-16 pb-12">
    <div class="mx-auto w-[min(1120px,calc(100%-2rem))] max-w-[54rem]">
      <p
        class="mb-[0.9rem] text-[0.82rem] font-bold tracking-[0.12em] text-[var(--color-plum)] uppercase"
      >
        News
      </p>
      <h1>{post.title}</h1>
      <p
        class="max-w-[48rem] text-[clamp(1.1rem,2vw,1.3rem)] text-[var(--color-text-soft)]"
      >
        {post.excerpt}
      </p>
      <p class="flex flex-wrap gap-[0.7rem] text-[var(--color-text-soft)]">
        <span>{formatDate(post.publishedAt)}</span>
        {post.authorName && <span>· {post.authorName}</span>}
      </p>
    </div>
  </section>

  <section class="py-10">
    <div
      class="mx-auto grid w-[min(1120px,calc(100%-2rem))] items-start gap-4 min-[981px]:grid-cols-[1.25fr_0.7fr]"
    >
      <article
        class="rounded-[18px] border border-[rgba(15,15,18,0.08)] bg-[rgba(255,255,255,0.9)] p-[1.4rem] shadow-[0_10px_30px_rgba(15,15,18,0.04)]"
      >
        <div
          class="max-w-[65ch] text-[var(--color-text)] [&_a]:text-[var(--color-plum)] [&_blockquote]:mb-4 [&_blockquote]:ml-0 [&_blockquote]:border-l-[3px] [&_blockquote]:border-l-[rgba(96,19,80,0.25)] [&_blockquote]:pl-4 [&_blockquote]:text-[var(--color-text-soft)] [&_h2]:mb-4 [&_h3]:mb-4 [&_ol]:mb-4 [&_ol]:pl-5 [&_p]:mb-4 [&_ul]:mb-4 [&_ul]:pl-5"
          set:html={markdownToHtml(post.body)}
        />
      </article>

      <aside
        class="sticky top-[6.2rem] rounded-[18px] border border-[rgba(15,15,18,0.08)] bg-[rgba(255,255,255,0.9)] p-[1.35rem] shadow-[0_10px_30px_rgba(15,15,18,0.04)] max-[980px]:static"
      >
        <h2>Want help applying this?</h2>
        <p>
          Send the scenario, especially the internal constraints and what has
          already been tried. That usually makes the next step clear.
        </p>
        <ActionLink
          href="/contact-us"
          label="Email your scenario"
          variant="primary"
        />
      </aside>
    </div>
  </section>
</BaseLayout>
